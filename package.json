{
  "name": "@rnm-dev/armory-repository",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "generate:types": "node scripts/generate-types.mjs",
    "generate:fixtures": "node tests/fixtures/archives/generate.mjs",
    "validate": "node scripts/validate.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:packages": "node scripts/check-packages.mjs",
    "check": "npm run validate && npm run typecheck && npm test && npm run test:packages",
    "build:package": "node scripts/build-package.mjs",
    "publish:package": "node scripts/publish-package.mjs"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "semver": "7.7.2",
    "tar": "7.5.20"
  },
  "devDependencies": {
    "@types/node": "24.0.15",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "5.8.3"
  }
}
