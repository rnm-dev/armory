{
  "schemaVersion": 1,
  "id": "playwright",
  "version": "0.1.0",
  "minPeonVersion": "0.0.1",
  "platforms": [
    { "os": "darwin", "arch": "arm64" },
    { "os": "darwin", "arch": "x64" },
    { "os": "linux", "arch": "arm64" },
    { "os": "linux", "arch": "x64" }
  ],
  "permissions": {
    "networkHosts": ["localhost", "127.0.0.1"],
    "hostPaths": [
      {
        "path": "/Applications/Google Chrome.app",
        "mode": "read",
        "purpose": "Launch an operator-installed Chrome browser on macOS for local web application testing."
      },
      {
        "path": "/Applications/Chromium.app",
        "mode": "read",
        "purpose": "Launch an operator-installed Chromium browser on macOS for local web application testing."
      },
      {
        "path": "/usr/bin/google-chrome",
        "mode": "read",
        "purpose": "Launch an operator-installed Chrome browser on Linux for local web application testing."
      },
      {
        "path": "/usr/bin/chromium",
        "mode": "read",
        "purpose": "Launch an operator-installed Chromium browser on Linux for local web application testing."
      }
    ]
  },
  "dependencies": [],
  "mcp": {
    "command": { "executable": "node", "args": ["dist/mcp.js"] },
    "toolPrefix": "playwright",
    "startupTimeoutMs": 15000,
    "callTimeoutMs": 60000
  }
}
