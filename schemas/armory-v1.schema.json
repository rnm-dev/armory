{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rnm-dev/armory/main/schemas/armory-v1.schema.json",
  "title": "ArmoryCatalogV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "updatedAt", "packages"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "const": "rnm-dev/armory" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "packages": {
      "type": "array",
      "items": { "$ref": "#/$defs/package" }
    }
  },
  "$defs": {
    "packageId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "semver": { "type": "string", "format": "semver" },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch"],
      "properties": {
        "os": { "enum": ["darwin", "linux"] },
        "arch": { "enum": ["x64", "arm64"] }
      }
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "size", "sha256"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://" },
        "size": { "type": "integer", "minimum": 1, "maximum": 268435456 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "version": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "minPeonVersion", "platforms", "archive"],
      "properties": {
        "version": { "$ref": "#/$defs/semver" },
        "minPeonVersion": { "$ref": "#/$defs/semver" },
        "platforms": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/platform" } },
        "archive": { "$ref": "#/$defs/archive" }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "summary", "publisher", "documentationUrl", "latest", "requirements", "versions"],
      "properties": {
        "id": { "$ref": "#/$defs/packageId" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 120 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "publisher": { "const": "rnm-dev" },
        "documentationUrl": { "type": "string", "format": "uri", "pattern": "^https://github\\.com/rnm-dev/armory/" },
        "latest": { "$ref": "#/$defs/semver" },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": ["credentials", "hostWrites"],
          "properties": {
            "credentials": { "type": "boolean" },
            "hostWrites": { "type": "boolean" }
          }
        },
        "versions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/version" } }
      }
    }
  }
}
